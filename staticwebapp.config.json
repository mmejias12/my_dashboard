{
  "routes": [
    {
      "route": "/proxy/ops",
      "rewrite": "/api/ops"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/data/*",
      "/api/*",
      "/assets/*",
      "/images/*",
      "/*.html",
      "/*.{json,xml,txt,ico,png,jpg,jpeg,svg,gif,webp,css,js,map,woff,woff2,ttf,eot,html}"
    ]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff"
  }
}
